        "source": [
          "# TODO: Import a random forest classifier\n",
          "from sklearn.ensemble import RandomForestClassifier\n",
          "\n",
          "model = RandomForestClassifier(n_estimators=10, random_state=42)\n",
          "print(\"Random forest ready!\")"
        ]
      },
      {
        "cell_type": "code",
        "execution_count": null,
        "metadata": {},
        "outputs": [],
        "source": [
          "# TODO: Create simple training data\n",
          "X = [[0, 0], [1, 1], [1, 0], [0, 1]]\n",
          "y = [0, 1, 1, 0]\n",
          "\n",
          "model.fit(X, y)\n",
          "print(\"Model trained!\")"
        ]
      },
      {
        "cell_type": "code",
        "execution_count": null,
        "metadata": {},
        "outputs": [],
        "source": [
          "# TODO: Make a prediction\n",
          "prediction = model.predict([[1, 1]])\n",
          "print(\"Prediction:\", prediction[0])"
        ]
      }
    ],
