          "\n",
          "# TODO: Compute entropy for a two-class distribution\n",
          "probs = [0.6, 0.4]\n",
          "entropy = -sum(p * math.log2(p) for p in probs if p > 0)\n",
          "print(f\"Entropy: {entropy:.3f}\")"
        ]
