          "# TODO: Train a simple regression tree\n",
          "from sklearn.tree import DecisionTreeRegressor\n",
          "\n",
          "X = [[1], [2], [3], [4]]\n",
          "y = [2.0, 4.0, 6.0, 8.0]\n",
          "model = DecisionTreeRegressor(max_depth=2, random_state=42)\n",
          "model.fit(X, y)\n",
          "print(\"Prediction for x=2.5:\", model.predict([[2.5]])[0])"
        ]
      }
