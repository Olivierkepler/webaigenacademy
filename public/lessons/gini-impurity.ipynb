      "source": [
        "# TODO: Compute Gini impurity for a small class distribution\n",
        "class0 = 6\n",
        "class1 = 4\n",
        "total = class0 + class1\n",
        "p0 = class0 / total\n",
        "p1 = class1 / total\n",
        "gini = 1 - (p0 ** 2 + p1 ** 2)\n",
        "print(f\"Gini impurity: {gini:.3f}\")"
      ]
    }
  ],
