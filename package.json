{
  "name": "webaigenacademy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "sync:course-notebooks": "sh scripts/sync-course-notebooks.sh",
    "build:jupyterlite": "npm run sync:course-notebooks && sh -c 'JUPYTER=\"${JUPYTER:-jupyter}\"; [ -x .venv-jupyterlite/bin/jupyter ] && JUPYTER=.venv-jupyterlite/bin/jupyter; \"$JUPYTER\" lite build --contents jupyterlite-content --output-dir public/jupyterlite' && node scripts/generate-contents-api.js"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "fs": "^0.0.1-security",
    "katex": "^0.17.0",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
